        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (23b): discussion of evidence limitations must be present." ;
    ] ;
    sh:property [
        sh:path revaise:discussion_process_limitations ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (23c): discussion of process limitations must be present." ;
    ] ;
    sh:property [
        sh:path revaise:discussion_implications ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (23d): discussion of implications must be present." ;
    ] .

proto:ProtocolShape
    a sh:NodeShape ;
    sh:targetClass revaise:Protocol ;
    sh:property [
        sh:path revaise:research_question ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (4): review objectives or research question must be present." ;
    ] ;
    sh:property [
        sh:path revaise:eligibility_criteria ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (5): eligibility criteria must be present." ;
    ] ;
    sh:property [
        sh:path revaise:registration_id ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (24a): registration number must be present." ;
    ] ;
    sh:property [
        sh:path revaise:registration_url ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (24b): protocol access URL must be present." ;
    ] ;
    sh:property [
        sh:path revaise:amendments ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (24c): protocol amendments must be documented." ;
    ] .

proto:SearchStageShape
    a sh:NodeShape ;
    sh:targetClass revaise:SearchStage ;
    sh:property [
        sh:path revaise:databases ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (6): information sources searched must be specified." ;
    ] ;
    sh:property [
        sh:path revaise:search_queries ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (7): full search strategy must be present." ;
    ] .

proto:ScreeningStageShape
    a sh:NodeShape ;
    sh:targetClass revaise:ScreeningStage ;
    sh:property [
        sh:path revaise:screening_protocol ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
