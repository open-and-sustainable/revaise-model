    sh:property [
        sh:path revaise:rob_protocol ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (11): risk of bias assessment methods must be described." ;
    ] .

proto:SynthesisStageShape
    a sh:NodeShape ;
    sh:targetClass revaise:SynthesisStage ;
    sh:property [
        sh:path revaise:effect_measures ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (12): effect measures must be specified." ;
    ] ;
    sh:property [
        sh:path revaise:synthesis_protocol ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (13a): synthesis eligibility process must be described." ;
    ] ;
    sh:property [
        sh:path revaise:synthesis_methods ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (13b): data preparation methods must be described." ;
    ] ;
    sh:property [
        sh:path revaise:synthesis_visualizations ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (13c): methods for displaying results must be described." ;
    ] ;
    sh:property [
        sh:path revaise:heterogeneity_assessment ;
