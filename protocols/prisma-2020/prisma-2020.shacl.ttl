    sh:property [
        sh:path revaise:screening_rounds ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (16b): excluded studies with reasons must be recorded." ;
    ] .

proto:ExtractionStageShape
    a sh:NodeShape ;
    sh:targetClass revaise:ExtractionStage ;
    sh:property [
        sh:path revaise:extraction_protocol ;
