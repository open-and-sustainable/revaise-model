# prisma-2020 — SHACL shapes GENERATED from checklist.yaml. DO NOT EDIT BY HAND.
# Regenerate: python scripts/gen_protocol_shacl.py <checklist.yaml> <output.shacl.ttl>

@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix revaise: <https://open-and-sustainable.github.io/revaise-model/schema/> .
@prefix proto:   <https://open-and-sustainable.github.io/revaise-model/protocols/prisma-2020/shapes#> .

proto:ReviewShape
    a sh:NodeShape ;
    sh:targetClass revaise:Review ;
    sh:property [
        sh:path revaise:review_title ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (1): review title must be present." ;
    ] ;
    sh:property [
        sh:path revaise:review_abstract ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (2): review abstract must be present." ;
    ] ;
    sh:property [
        sh:path revaise:literature_records ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (17): at least one included study must be recorded." ;
    ] ;
    sh:property [
        sh:path revaise:funding_sources ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (25): funding sources must be declared." ;
    ] ;
    sh:property [
        sh:path revaise:conflicts_of_interest ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (26): competing interests declaration must be present." ;
    ] ;
    sh:property [
        sh:path revaise:data_availability ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (27): data availability statement must be present." ;
    ] .

proto:ReviewNarrativeShape
    a sh:NodeShape ;
    sh:targetClass revaise:ReviewNarrative ;
    sh:property [
        sh:path revaise:rationale ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (3): rationale for the review must be present." ;
    ] ;
    sh:property [
        sh:path revaise:discussion_interpretation ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (23a): discussion interpretation must be present." ;
    ] ;
    sh:property [
        sh:path revaise:discussion_evidence_limitations ;
