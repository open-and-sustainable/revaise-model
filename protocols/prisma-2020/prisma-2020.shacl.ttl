    ] .

proto:FlowDiagramShape
    a sh:NodeShape ;
    sh:targetClass revaise:FlowDiagram ;
    sh:property [
        sh:path revaise:records_identified ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (16a): flow diagram with number of records identified must be present." ;
    ] .

proto:LiteratureRecordShape
    a sh:NodeShape ;
    sh:targetClass revaise:LiteratureRecord ;
    sh:property [
        sh:path revaise:risk_of_bias ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (18): risk of bias assessment must be present for each included study." ;
    ] ;
    sh:property [
        sh:path revaise:study_results ;
        sh:minCount 1 ;
        sh:severity sh:Violation ;
        sh:message "PRISMA 2020 (19): results must be present for each included study." ;
    ] .
